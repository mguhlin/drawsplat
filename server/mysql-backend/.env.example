# Copy this file to .env and edit values before running docker compose up.
# Anything you leave as the default is INSECURE and only OK for local testing.

MYSQL_DATABASE=drawsplat
MYSQL_USER=drawsplat_app
MYSQL_PASSWORD=change-me-app
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_HOST_PORT=3306

# Where the static DrawSplatTM frontend is hosted. Use comma-separated origins.
# Leave blank only for local testing; set to your exact HTTPS origin in production.
CORS_ORIGIN=

# Public path prefix for the API. Keep in sync with the frontend backend URL.
API_BASE_PATH=/api/drawsplat/mysql

# Session token lifetime in hours.
SESSION_TTL_HOURS=24

# Server-side secret used to pepper password hashes. Long random string.
# Rotating this invalidates every stored password — every user has to reset.
DRAWSPLAT_PEPPER=change-this-to-a-long-random-string

# Optional bootstrap path for the first admin. Public self-registration normally
# creates teacher/parent users only. To create the first district/campus admin,
# temporarily set both values, register from one listed email with the requested
# admin role, then remove or set ALLOW_ADMIN_SELF_REGISTRATION=false.
ALLOW_ADMIN_SELF_REGISTRATION=false
BOOTSTRAP_ADMIN_EMAILS=

# Optional shared secret for /maintenance/delete-expired automation. If unset,
# the route requires a district_admin/campus_admin bearer token.
MAINTENANCE_TOKEN=

# Host port for the API. The container always listens on 8787 internally.
API_HOST_PORT=8787

# --- OAuth (Phase 4.2) ---------------------------------------------------
# Google OAuth Client ID. The browser-side ID token must match this audience.
# Leave blank to skip audience checking (NOT recommended in production).
GOOGLE_CLIENT_ID=

# (Microsoft auth uses MSAL.js on the client; the server only verifies the
# resulting access token against https://graph.microsoft.com/v1.0/me, so no
# server-side client ID is required here.)

# --- Cron (Phase 4.10) ---------------------------------------------------
# Set to 0 if you run multiple instances and want exactly one process to
# perform retention / time-limit enforcement.
DRAWSPLAT_CRON=1

# --- SIS / Clever (Phase 4.6) --------------------------------------------
# The Clever district token is stored in the database (config_key='sis:clever')
# after an admin POSTs it to /sis/clever/connect — no env var needed.
